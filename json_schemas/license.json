        "version": {
            "type": "string"
        },
        "uuid": {
            "type": "string"
        },
        "products": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "attributes": {
            "type": "object"
        },
        "timestamp": {
            "type": "integer"
        }
    },
